<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Configuración base: permitir HTTP en general para todas las conexiones -->
    <!-- Esto permite conexiones HTTP a cualquier servidor, incluyendo IPs con puertos -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Permitir HTTP para la IP del servidor específica (sin puerto, Android lo maneja automáticamente) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">190.116.29.99</domain>
    </domain-config>
    <!-- Permitir HTTP para localhost (desarrollo) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
    <!-- API HTTPS (autofirmado): confiar en el certificado embebido (res/raw).
         El servidor presenta CN/SAN localhost; las peticiones usan la IP en BASE_URL. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">186.101.59.140</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="@raw/api_backend_186_101_59_140" />
        </trust-anchors>
    </domain-config>
</network-security-config>
